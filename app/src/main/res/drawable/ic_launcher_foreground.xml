<?xml version="1.0" encoding="utf-8"?>
<!-- Thirai launcher mark: a single amber play triangle with softly rounded
     corners, centred inside the adaptive-icon safe zone. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Play triangle at ~75% size, centred on (54,54), for more breathing room
         inside the adaptive-icon mask. -->
    <path
        android:pathData="M45,39 L45,69 L72,54 Z"
        android:fillColor="#E8A33D"
        android:strokeColor="#E8A33D"
        android:strokeWidth="7"
        android:strokeLineJoin="round"
        android:strokeLineCap="round" />
</vector>
