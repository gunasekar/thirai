<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <!-- Brand header. Nothing here is clickable — only the poster tiles below
         respond to taps (they play). The app is opened from its launcher icon. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <!-- Raster (not the app's vector ic_logo): RemoteViews can't inflate a
             VectorDrawable via android:src before API 31, which made the whole
             widget fail to load on Android 11 and below. -->
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_logo_widget"
            android:contentDescription="@string/app_name" />

        <!-- English wordmark + amber accent dot. System bold, not the app's
             @font/bricolage_bold: a custom font resource in a RemoteViews layout
             throws InflateException when the launcher renders the widget on API
             < 31, which kept it out of the widget picker on Android 11. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/app_name"
            android:textColor="#F3EEE4"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="."
            android:textColor="#E8A33D"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_hint"
            android:textColor="#8C8474"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:layout_marginBottom="10dp">

        <LinearLayout android:id="@+id/show_tile_1"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginEnd="8dp"
            android:orientation="vertical">
            <ImageView android:id="@+id/show_poster_1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitXY" android:background="@drawable/show_placeholder"
                android:contentDescription="@string/app_name" />
            <TextView android:id="@+id/show_title_1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#D8CFBF" android:textSize="11sp" android:maxLines="1"
                android:ellipsize="end" android:layout_marginTop="6dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/show_tile_2"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginEnd="8dp"
            android:orientation="vertical">
            <ImageView android:id="@+id/show_poster_2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitXY" android:background="@drawable/show_placeholder"
                android:contentDescription="@string/app_name" />
            <TextView android:id="@+id/show_title_2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#D8CFBF" android:textSize="11sp" android:maxLines="1"
                android:ellipsize="end" android:layout_marginTop="6dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/show_tile_3"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <ImageView android:id="@+id/show_poster_3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitXY" android:background="@drawable/show_placeholder"
                android:contentDescription="@string/app_name" />
            <TextView android:id="@+id/show_title_3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#D8CFBF" android:textSize="11sp" android:maxLines="1"
                android:ellipsize="end" android:layout_marginTop="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout android:id="@+id/show_tile_4"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginEnd="8dp"
            android:orientation="vertical">
            <ImageView android:id="@+id/show_poster_4"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitXY" android:background="@drawable/show_placeholder"
                android:contentDescription="@string/app_name" />
            <TextView android:id="@+id/show_title_4"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#D8CFBF" android:textSize="11sp" android:maxLines="1"
                android:ellipsize="end" android:layout_marginTop="6dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/show_tile_5"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginEnd="8dp"
            android:orientation="vertical">
            <ImageView android:id="@+id/show_poster_5"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitXY" android:background="@drawable/show_placeholder"
                android:contentDescription="@string/app_name" />
            <TextView android:id="@+id/show_title_5"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#D8CFBF" android:textSize="11sp" android:maxLines="1"
                android:ellipsize="end" android:layout_marginTop="6dp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/show_tile_6"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <ImageView android:id="@+id/show_poster_6"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitXY" android:background="@drawable/show_placeholder"
                android:contentDescription="@string/app_name" />
            <TextView android:id="@+id/show_title_6"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#D8CFBF" android:textSize="11sp" android:maxLines="1"
                android:ellipsize="end" android:layout_marginTop="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Transport controls for whatever is playing on the TV: restart the current
         item, or skip to the next episode. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/widget_restart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/widget_button_bg"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:gravity="center"
            android:text="@string/widget_restart"
            android:textColor="#E8A33D"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/widget_button_bg"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:gravity="center"
            android:text="@string/widget_next"
            android:textColor="#E8A33D"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
